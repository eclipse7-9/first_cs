@page
@model WebApplication1.Pages.CrearProductoModel

<div class="product-card card fade-up">
    <div class="card-header bg-transparent border-0">
        <h2 class="mb-0">Crear Producto</h2>
    </div>
    <div class="card-body">
        <form method="post" novalidate>
            <div class="mb-3">
                <label asp-for="Producto.Nombre" class="form-label"></label>
                <input asp-for="Producto.Nombre" class="form-control animate-input" />
                <span asp-validation-for="Producto.Nombre" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Producto.Descripcion" class="form-label"></label>
                <input asp-for="Producto.Descripcion" class="form-control animate-input" />
                <span asp-validation-for="Producto.Descripcion" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Producto.Precio" class="form-label"></label>
                    <input asp-for="Producto.Precio" class="form-control animate-input" />
                    <span asp-validation-for="Producto.Precio" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Producto.Stock" class="form-label"></label>
                    <input asp-for="Producto.Stock" class="form-control animate-input" />
                    <span asp-validation-for="Producto.Stock" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex align-items-center gap-2">
                <button type="submit" class="btn btn-primary">Guardar</button>
                <a asp-page="/Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>

        @if (Model.Mensaje != null)
        {
            <div class="mt-3 alert alert-info fade-up">@Model.Mensaje</div>
        }
    </div>
</div>
